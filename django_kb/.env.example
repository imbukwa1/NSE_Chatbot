DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5175
# Production deployments should set DEBUG=false and use HTTPS.
DJANGO_SECURE_SSL_REDIRECT=false

# sqlite, postgresql, or mysql
DJANGO_DB_ENGINE=sqlite
DJANGO_DB_NAME=nse_knowledge
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

KB_MIN_CONFIDENCE=0.75
KB_EMBEDDINGS_ENABLED=false
KB_EMBEDDING_MODEL=all-MiniLM-L6-v2

FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_CHAT_MODEL=Qwen/Qwen3-8B
